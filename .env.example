# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA commite o .env — ele está no .gitignore.

SENHASEGURA_URL=https://seu-vault.empresa.com
SENHASEGURA_ID=seu_client_id
SENHASEGURA_SECRET=seu_client_secret

# Opcional
OUTPUT_CSV=credentials_export.csv
REQUEST_DELAY=0.3
VERIFY_SSL=true