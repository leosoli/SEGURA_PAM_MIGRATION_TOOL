# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA commite o .env — ele está no .gitignore.

# ── Vault de ORIGEM (senhasegura_export.py) ──
SENHASEGURA_URL=https://vault-origem.empresa.com
SENHASEGURA_ID=seu_client_id_origem
SENHASEGURA_SECRET=seu_client_secret_origem
SENHASEGURA_VERSION=3.31      # versão do vault de origem (ex: 3.30, 3.33, 4.0, 4.2)

# ── Vault de DESTINO (senhasegura_migrate.py) ──
DEST_URL=https://vault-destino.empresa.com
DEST_ID=seu_client_id_destino
DEST_SECRET=seu_client_secret_destino
DEST_VERSION=4.2              # versão do vault de destino (ex: 3.30, 3.33, 4.0, 4.2)

# ── Comparação de escopo (compare_credentials.py) ──
SCOPE_XLSX=scope.xlsx          # arquivo xlsx exportado do senhasegura UI
SCOPE_SHEET=Sheet1             # nome da aba na planilha
COMPARISON_REPORT=comparison_report.csv

# ── Arquivos ──
OUTPUT_CSV=credentials_export.csv
INPUT_CSV=credentials_export.csv
REPORT_CSV=migration_report.csv

# ── Opcional ──
REQUEST_DELAY=0.3
VERIFY_SSL=false